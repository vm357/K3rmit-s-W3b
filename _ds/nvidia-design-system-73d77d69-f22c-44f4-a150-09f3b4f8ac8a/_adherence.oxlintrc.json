{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:tag|accent|outline)$/]",
        "message": "<Badge> variant must be one of 'tag' | 'accent' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|icon|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, icon, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|outline-on-dark|ghost-link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'outline-on-dark' | 'ghost-link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:cornerSquare|corner|padding|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: cornerSquare, corner, padding, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='corner'] > Literal[value!=/^(?:top-left|top-right|bottom-left|bottom-right)$/]",
        "message": "<Card> corner must be one of 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:xl|xxl|none)$/]",
        "message": "<Card> padding must be one of 'xl' | 'xxl' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CornerSquare'] > JSXAttribute > JSXIdentifier[name!=/^(?:corner|size|key|ref|className|style|children)$/]",
        "message": "<CornerSquare> doesn't accept that prop. Declared props: corner, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='CornerSquare'] > JSXAttribute[name.name='corner'] > Literal[value!=/^(?:top-left|top-right|bottom-left|bottom-right)$/]",
        "message": "<CornerSquare> corner must be one of 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|search|invalid|disabled|value|defaultValue|placeholder|onChange|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, search, invalid, disabled, value, defaultValue, placeholder, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillTabsItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<PillTabsItem> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCallout'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|caption|cornerSquare|corner|key|ref|className|style|children)$/]",
        "message": "<StatCallout> doesn't accept that prop. Declared props: value, caption, cornerSquare, corner."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCallout'] > JSXAttribute[name.name='corner'] > Literal[value!=/^(?:top-left|top-right|bottom-left|bottom-right)$/]",
        "message": "<StatCallout> corner must be one of 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
